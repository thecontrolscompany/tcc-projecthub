# TCC ProjectHub — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Microsoft / Azure AD (Graph API) ─────────────────────
# Azure AD â€” TCC ProjectHub app registration (tenant: controlsco.net)
NEXT_PUBLIC_AZURE_CLIENT_ID=0777b14d-29c4-4186-8d8e-4a8f43de6589
NEXT_PUBLIC_AZURE_TENANT_ID=7eec7a09-a47b-4bf1-a877-80fd5323c774
# Client secret â€” get from Azure portal, Certificates & secrets (never commit the actual value)
AZURE_CLIENT_SECRET=
# Redirect URI to register in Azure: http://localhost:3000/auth/callback/microsoft

# ── Power BI Embedded ─────────────────────────────────────
# Found in: Power BI workspace > Embed for your customers
# Required only for the analytics Power BI panel
NEXT_PUBLIC_POWERBI_WORKSPACE_ID=your_workspace_id
NEXT_PUBLIC_POWERBI_REPORT_ID=your_report_id
# Service principal for server-side token generation:
POWERBI_CLIENT_SECRET=your_azure_client_secret

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://internal.thecontrolscompany.com
RESEND_API_KEY=re_...

# SharePoint site: https://controlsco.sharepoint.com/sites/TCCProjects
# Site ID â€” discovered automatically by migration tool on first run, then cache here
SHAREPOINT_SITE_ID=
# Default document library drive ID â€” same, cache after first run
SHAREPOINT_DRIVE_ID=

# Optional legacy TCC Time bridge used during migration and fallback reads.
# After the merged time tables are populated in ProjectHub, the /time module can read locally.
TCC_TIME_SUPABASE_URL=https://YOUR_TCC_TIME_PROJECT.supabase.co
TCC_TIME_SUPABASE_SERVICE_ROLE_KEY=your_tcc_time_service_role_key_here
